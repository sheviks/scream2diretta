# Logrotate configuration for scream2diretta
# Install to /etc/logrotate.d/scream2diretta
#
# Both 'daily' and 'size' are present: rotation triggers on whichever
# condition is met first.  This prevents unbounded growth during
# extended debug sessions or persistent underrun storms.
/var/log/scream2diretta.log {
    daily
    size 10M
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    create 0644 root root
}
